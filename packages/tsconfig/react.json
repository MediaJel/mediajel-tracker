{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "MediaJel React (modern)",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "target": "ES2021",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "useDefineForClassFields": true,
    "allowJs": false
  }
}
