{
    "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
    "description": "Schema for enhanced transaction events with additional e-commerce attributes",
    "self": {
        "vendor": "com.mediajel.events",
        "name": "enhanced_transaction",
        "format": "jsonschema",
        "version": "1-0-0"
    },
    "type": "object",
    "properties": {
        "transaction_ids": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Array of unique identifiers for the transactions"
        },
        "transaction_affiliation": {
            "type": [
                "string",
                "null"
            ],
            "description": "Affiliation for the transaction"
        },
        "transaction_total": {
            "type": [
                "number",
                "null"
            ],
            "description": "Total revenue amount of the transaction"
        },
        "transaction_tax": {
            "type": [
                "number",
                "null"
            ],
            "description": "Tax amount for the transaction"
        },
        "transaction_shipping": {
            "type": [
                "number",
                "null"
            ],
            "description": "Shipping cost for the transaction"
        },
        "transaction_city": {
            "type": [
                "string",
                "null"
            ],
            "description": "City of the transaction"
        },
        "transaction_state": {
            "type": [
                "string",
                "null"
            ],
            "description": "State of the transaction"
        },
        "transaction_country": {
            "type": [
                "string",
                "null"
            ],
            "description": "Country of the transaction"
        },
        "transaction_currency": {
            "type": [
                "string",
                "null"
            ],
            "description": "Currency of the transaction"
        },
        "transaction_discount": {
            "type": [
                "number",
                "null"
            ],
            "description": "Discount amount applied to the transaction"
        },
        "transaction_coupon_code": {
            "type": [
                "string",
                "null"
            ],
            "description": "Coupon code used for the transaction"
        },
        "transaction_payment_method": {
            "type": [
                "string",
                "null"
            ],
            "description": "Method of payment used for the transaction"
        },
        "transaction_total_quantity": {
            "type": [
                "integer",
                "null"
            ],
            "description": "Total number of items in the transaction"
        }
    },
    "additionalProperties": true
}