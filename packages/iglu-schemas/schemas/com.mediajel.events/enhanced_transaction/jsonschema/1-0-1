{
  "$schema": "http://iglucentral.com/schemas/com.snowplowanalytics.self-desc/schema/jsonschema/1-0-0#",
  "description": "Schema for enhanced transaction events with additional e-commerce attributes",
  "self": {
    "vendor": "com.mediajel.events",
    "name": "enhanced_transaction",
    "format": "jsonschema",
    "version": "1-0-1"
  },
  "type": "object",
  "properties": {
    "transaction_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of unique identifiers for the transactions"
    },
    "discount": {
      "type": [
        "number",
        "null"
      ],
      "description": "Discount amount applied to the transaction"
    },
    "coupon_code": {
      "type": [
        "string",
        "null"
      ],
      "description": "Coupon code used for the transaction"
    },
    "revenue": {
      "type": [
        "number",
        "null"
      ],
      "description": "Total revenue amount of the transaction"
    },
    "currency": {
      "type": [
        "string",
        "null"
      ],
      "description": "Currency code for the transaction (e.g., USD)"
    },
    "payment_method": {
      "type": [
        "string",
        "null"
      ],
      "description": "Method of payment used for the transaction"
    },
    "total_quantity": {
      "type": [
        "integer",
        "null"
      ],
      "description": "Total number of items in the transaction"
    },
    "tax": {
      "type": [
        "number",
        "null"
      ],
      "description": "Tax amount for the transaction"
    },
    "shipping": {
      "type": [
        "number",
        "null"
      ],
      "description": "Shipping cost for the transaction"
    },
    "test": {
      "type": [
        "string",
        "null"
      ],
      "description": "indicates whether the event is a test event"
    },
    "cart": {
      "type": [
        "string",
        "null"
      ],
      "description": "Environment of the shop where the transaction took place"
    }
  },
  "additionalProperties": true
}
