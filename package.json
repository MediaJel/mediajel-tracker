{
  "name": "mediajel-tracker-monorepo",
  "version": "1.0.0",
  "description": "MediaJel tracker monorepo — the universal tag (apps/tracker) and the Integrations training site (apps/integrations).",
  "private": true,
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "bun run scripts/dev.ts",
    "dev:site": "turbo run dev --filter=@mediajel/integrations",
    "dev:raw": "turbo run dev",
    "check": "turbo run check",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "tracker:build": "turbo run build --filter=mediajel-tracker",
    "tracker:generate-environments": "turbo run generate-environments --filter=mediajel-tracker",
    "micro:up": "docker compose up -d snowplow-micro",
    "micro:down": "docker compose down",
    "micro:logs": "docker compose logs -f snowplow-micro",
    "schemas:sync": "bun run packages/iglu-schemas/scripts/sync.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MediaJel/mediajel-tracker.git"
  },
  "author": "Pacholo Amit",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/MediaJel/mediajel-tracker/issues"
  },
  "homepage": "https://github.com/MediaJel/mediajel-tracker#readme",
  "//browserslist": "Old-browser support for the tag is enforced per-app in apps/tracker (package.json browserslist + .browserslistrc). Kept here only as a backstop; do NOT remove without confirming apps/tracker still targets 'since 2017-06'.",
  "browserslist": [
    "since 2017-06"
  ],
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.3.3",
    "turbo": "^2.4.4",
    "typescript": "^5.6.3"
  }
}
