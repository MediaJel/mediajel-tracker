{
  "compilerOptions": {
    "lib": [
      "es5",
      "es6",
      "dom",
      "ES2018"
    ],
    "baseUrl": ".",
    "strictNullChecks": true,
    "noImplicitAny": false,
    "paths": {
      "src/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "server/**/*"
  ],
  "exclude": [
    "node_modules/*",
    "src/scripts/**/*"
  ]
}